      "replace_string": "<!-- UI_START --><div class=\"html-safe-wrap\"><style>.wnb-wrap{max-width:720px;margin:18px auto;box-sizing:border-box;text-align:center}.wnb-hr{border:0;height:1px;background-image:linear-gradient(to right, rgba(0,0,0,0), rgba(150,150,150,0.75), rgba(0,0,0,0));margin:10px 0}.wnb-kicker{font-family:Courier New, monospace;letter-spacing:.22rem;font-size:.78rem;opacity:.78;margin-top:2px}.wnb-title{font-family:Georgia, Times New Roman, serif;font-weight:normal;margin:8px 0 2px;line-height:1.15}.wnb-note{font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial;font-size:12px;opacity:.65;letter-spacing:.06em;margin-top:6px}.wnb-note:empty{display:none}.wnb-grid{margin-top:12px;display:grid;gap:10px;grid-template-columns:1fr}@media(min-width:640px){.wnb-grid{grid-template-columns:1fr 1fr}}.wnb-btn{width:100%;text-align:left;cursor:pointer;box-sizing:border-box;border-radius:16px;border:2px solid rgba(255,255,255,.9);background:linear-gradient(135deg,rgba(255,240,248,.92),rgba(235,228,255,.88));box-shadow:0 10px 22px rgba(20,10,30,.20);color:#14121a;padding:12px 12px 12px 46px;font-family:system-ui,-apple-system,Segoe UI,Roboto,Arial;font-weight:650;line-height:1.2;position:relative;transition:transform .12s ease, box-shadow .12s ease, filter .12s ease}.wnb-btn:empty{display:none}.wnb-btn::before{content:attr(data-opt);position:absolute;left:12px;top:50%;transform:translateY(-50%);width:26px;height:26px;border-radius:10px;display:flex;align-items:center;justify-content:center;font-family:Courier New, monospace;font-weight:700;font-size:.9rem;opacity:.85;border:1px solid rgba(20,10,30,.14);background:rgba(255,255,255,.85)}.wnb-btn:hover{transform:translateY(-1px);box-shadow:0 14px 30px rgba(20,10,30,.22);filter:saturate(1.05)}.wnb-btn:active{transform:translateY(0);box-shadow:0 10px 22px rgba(20,10,30,.20)}</style><div class=\"wnb-wrap\"><hr class=\"wnb-hr\"><div class=\"wnb-kicker\">CHOICE SET</div><h2 class=\"wnb-title\">$1</h2><div class=\"wnb-